# Source archive. The app treats this directory as read-only.
UNI_RAG_COURSES_ROOT=Courses

# Generated local application data. This directory is gitignored.
UNI_RAG_DATA_DIR=data
UNI_RAG_SQLITE_PATH=data/uni_rag.sqlite
UNI_RAG_CHROMA_DIR=data/indexes/vector
UNI_RAG_RUNS_DIR=data/runs

# Runtime behavior.
UNI_RAG_LOG_LEVEL=INFO
UNI_RAG_OCR_ENABLED=false

# Optional production model settings. Leave these unset until routing and
# answer generation are implemented. Vector commands require a supported
# embedding model either here or through --model.
# UNI_RAG_LLM_PROVIDER=
# UNI_RAG_LLM_MODEL=
# UNI_RAG_EMBEDDING_MODEL=

# Supported Hugging Face embedding profiles:
# BAAI/bge-m3
# jinaai/jina-embeddings-v3
# jinaai/jina-embeddings-v5-text-small
# google/embeddinggemma-300m
# Install the vector stack before selecting a profile: uv sync --extra embeddings
# Model-specific access or authentication may also be required.

# Retrieval defaults.
UNI_RAG_KEYWORD_TOP_K=20
UNI_RAG_SEMANTIC_TOP_K=20
UNI_RAG_FINAL_TOP_K=10
UNI_RAG_RRF_K=60
UNI_RAG_METADATA_TOP_K=20
UNI_RAG_SEMANTIC_QUERY_LIMIT=3
UNI_RAG_ROUTER_MIN_CONFIDENCE=0.60
UNI_RAG_COURSE_FUZZY_THRESHOLD=90
UNI_RAG_FILENAME_FUZZY_THRESHOLD=85
UNI_RAG_PATH_FUZZY_THRESHOLD=90

# Provider API keys belong only in .env, never in this template.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
