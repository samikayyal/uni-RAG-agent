# Source archive. The app treats this directory as read-only.
UNI_RAG_COURSES_ROOT=Courses

# Generated local application data. This directory is gitignored.
UNI_RAG_DATA_DIR=data
UNI_RAG_SQLITE_PATH=data/uni_rag.sqlite
UNI_RAG_CHROMA_DIR=data/indexes/vector
UNI_RAG_RUNS_DIR=data/runs

# Runtime behavior.
UNI_RAG_LOG_LEVEL=INFO
UNI_RAG_OCR_ENABLED=false

# Provider defaults for local tests. Replace with real providers when needed.
UNI_RAG_LLM_PROVIDER=fake
UNI_RAG_LLM_MODEL=fake-chat
UNI_RAG_EMBEDDING_PROVIDER=fake
UNI_RAG_EMBEDDING_MODEL=fake-embedding
UNI_RAG_EMBEDDING_DIM=384
UNI_RAG_USE_FAKE_LLM=true
UNI_RAG_USE_FAKE_EMBEDDINGS=true

# Real Hugging Face local embedding models (optional).
# Install the optional dependencies first: uv sync --extra embeddings
# Then either flip the defaults below, or override per command without editing
# this file, e.g.:
#   uv run -m uni_rag_agent index vector --model BAAI/bge-m3 --rebuild
#   uv run -m uni_rag_agent search semantic "distributed computation" --model BAAI/bge-m3
# Known real profiles: BAAI/bge-m3, jinaai/jina-embeddings-v3,
# jinaai/jina-embeddings-v5-text-small, google/embeddinggemma-300m
# (jina models may require trust_remote_code; embeddinggemma is gated and needs a
# Hugging Face token). Set UNI_RAG_EMBEDDING_DIM to match the chosen model.
# UNI_RAG_EMBEDDING_PROVIDER=huggingface
# UNI_RAG_EMBEDDING_MODEL=BAAI/bge-m3
# UNI_RAG_EMBEDDING_DIM=1024
# UNI_RAG_USE_FAKE_EMBEDDINGS=false

# Retrieval defaults.
UNI_RAG_KEYWORD_TOP_K=20
UNI_RAG_SEMANTIC_TOP_K=20
UNI_RAG_FINAL_TOP_K=10
UNI_RAG_RRF_K=60

# Provider API keys belong only in .env, never in this template.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
