# =============================================================================
# 1. DATA PATHS
# =============================================================================

# Read-only source archive containing one folder per course.
UNI_RAG_COURSES_ROOT=Courses

# Generated application state. The whole directory is gitignored and can be
# deleted when you want to rebuild the inventory, extraction, and indexes.
UNI_RAG_DATA_DIR=data
UNI_RAG_SQLITE_PATH=data/uni_rag.sqlite
UNI_RAG_CHROMA_DIR=data/indexes/vector
UNI_RAG_RUNS_DIR=data/runs
    
# =============================================================================
# 2. GENERAL RUNTIME BEHAVIOR
# =============================================================================

UNI_RAG_LOG_LEVEL=INFO

# Applies only to scanned PDFs. Standalone images remain metadata-only.
# Tesseract must also be installed and available when this is enabled.
UNI_RAG_OCR_ENABLED=false

# =============================================================================
# 3. EMBEDDING MODEL — REQUIRED FOR VECTOR AND HYBRID SEARCH
# =============================================================================

# Required by: index vector, search semantic, retrieve, evidence build, and ask.
# You may leave this unset and pass `--model` to individual commands instead.
# Install the extra that matches the selected provider:
#   Local Hugging Face:       uv sync --extra embeddings
#   Hosted Google/Nebius:     uv sync --extra embeddings-cloud
# Provider inference is registry-based. Do not add a provider variable: there is
# no UNI_RAG_EMBEDDING_PROVIDER.
#
# Reviewed local Hugging Face profiles (declared dimensions):
#   BAAI/bge-m3
#   jinaai/jina-embeddings-v3
#   jinaai/jina-embeddings-v5-text-small
#   google/embeddinggemma-300m
#
# Reviewed hosted profiles (declared dimensions):
#   google/gemini-embedding-001       (3072; alias gemini-embedding-001)
#   Qwen/Qwen3-Embedding-8B           (4096; Nebius Token Factory)


# UNI_RAG_EMBEDDING_MODEL=BAAI/bge-m3

# =============================================================================
# 4. QUERY-PLANNER LLM 
# =============================================================================

# These two values must be configured together.
# Install provider integrations first with: uv sync --extra llm
# Supported providers: openai, anthropic, gemini, ollama

# UNI_RAG_LLM_PROVIDER=
# UNI_RAG_LLM_MODEL=

# =============================================================================
# 5. ANSWER-GENERATION LLM — REQUIRED FOR NON-EMPTY ANSWERS
# =============================================================================

# This is deliberately separate from the query-planner LLM above. It generates
# the final cited answer from an existing evidence packet. These two values must
# be configured together. Supported providers: openai, anthropic, gemini, ollama
#
# UNI_RAG_ANSWER_LLM_PROVIDER=ollama
# UNI_RAG_ANSWER_LLM_MODEL=your-answer-model

# Number of retries after an invalid model-produced answer.
UNI_RAG_ANSWER_MAX_RETRIES=1

# Maximum messages retained in an in-memory `ask` planner session.
UNI_RAG_ANSWER_SESSION_MESSAGE_LIMIT=20

# Whitespace-estimated limit for the complete answer-model input prompt.
UNI_RAG_ANSWER_PROMPT_MAX_TOKENS=16000

# End-to-end timeout for an `ask` request, in seconds.
UNI_RAG_ASK_TIMEOUT_SECONDS=120

# =============================================================================
# 6. RETRIEVAL AND EVIDENCE TUNING — DEFAULTS ARE USUALLY FINE
# =============================================================================

# Candidate counts returned by each retrieval method.
UNI_RAG_METADATA_TOP_K=20
UNI_RAG_KEYWORD_TOP_K=20
UNI_RAG_SEMANTIC_TOP_K=20

# Maximum number of fused results retained after hybrid retrieval.
UNI_RAG_FINAL_TOP_K=10

# Reciprocal Rank Fusion constant.
UNI_RAG_RRF_K=60

# Maximum semantic queries accepted from one validated query plan.
UNI_RAG_SEMANTIC_QUERY_LIMIT=3

# Query-plan confidence and metadata fuzzy-match thresholds.
UNI_RAG_QUERY_PLAN_MIN_CONFIDENCE=0.60
UNI_RAG_FILENAME_FUZZY_THRESHOLD=85
UNI_RAG_PATH_FUZZY_THRESHOLD=90

# Evidence packets retain whole chunks in fused-result order without exceeding
# this positive, whitespace-estimated token budget.
UNI_RAG_EVIDENCE_MAX_TOKENS=12000

# =============================================================================
# 7. PROVIDER CREDENTIALS — ADD ONLY TO `.env`, NEVER COMMIT REAL KEYS
# =============================================================================

# Direct Gemini embedding construction uses GOOGLE_API_KEY. Vertex AI is not
# supported by the embedding contract.
# Nebius embedding construction uses NEBIUS_API_KEY and the fixed Token Factory
# endpoint https://api.tokenfactory.nebius.com/v1/.
# Hosted profiles send eligible course text and semantic queries to the external
# provider and may incur charges. Local profiles keep model execution local
# apart from model downloads as applicable.
# Credentialed hosted smokes are optional; keep keys out of logs and telemetry.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# NEBIUS_API_KEY=
