# Source archive. The app treats this directory as read-only.
UNI_RAG_COURSES_ROOT=Courses

# Generated local application data. This directory is gitignored.
UNI_RAG_DATA_DIR=data
UNI_RAG_SQLITE_PATH=data/uni_rag.sqlite
UNI_RAG_CHROMA_DIR=data/indexes/vector
UNI_RAG_RUNS_DIR=data/runs

# Runtime behavior.
UNI_RAG_LOG_LEVEL=INFO
UNI_RAG_OCR_ENABLED=false

# Production model settings remain optional globally. `retrieve` requires both
# LLM values plus a supported embedding model (here or through --model).
# UNI_RAG_LLM_PROVIDER=
# UNI_RAG_LLM_MODEL=
# UNI_RAG_EMBEDDING_MODEL=

# Answer generation is intentionally separate from planner configuration. The
# pair is optional globally and required only when a non-empty evidence packet
# reaches answer generation.
# UNI_RAG_ANSWER_LLM_PROVIDER=
# UNI_RAG_ANSWER_LLM_MODEL=
UNI_RAG_ANSWER_MAX_RETRIES=1
UNI_RAG_ANSWER_SESSION_MESSAGE_LIMIT=20
# Whitespace-estimated maximum for the complete answer-model input prompt.
UNI_RAG_ANSWER_PROMPT_MAX_TOKENS=16000
UNI_RAG_ASK_TIMEOUT_SECONDS=120

# Supported Hugging Face embedding profiles:
# BAAI/bge-m3
# jinaai/jina-embeddings-v3
# jinaai/jina-embeddings-v5-text-small
# google/embeddinggemma-300m
# Install the vector stack before selecting a profile: uv sync --extra embeddings
# Model-specific access or authentication may also be required.

# Retrieval defaults.
UNI_RAG_KEYWORD_TOP_K=20
UNI_RAG_SEMANTIC_TOP_K=20
UNI_RAG_FINAL_TOP_K=10
UNI_RAG_RRF_K=60
UNI_RAG_METADATA_TOP_K=20
UNI_RAG_SEMANTIC_QUERY_LIMIT=3
UNI_RAG_QUERY_PLAN_MIN_CONFIDENCE=0.60
UNI_RAG_FILENAME_FUZZY_THRESHOLD=85
UNI_RAG_PATH_FUZZY_THRESHOLD=90
UNI_RAG_EVIDENCE_MAX_TOKENS=12000

# Evidence packets keep whole authoritative chunks and select greedily in RRF
# order without exceeding this positive whitespace-estimated token budget.

# Provider API keys belong only in .env, never in this template.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
